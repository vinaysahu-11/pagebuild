rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Files can be any path, including nested paths
    match /{allPaths=**} {
      // Allow read access for authenticated users
      allow read: if request.auth != null;
      // Allow write access only for the user who owns the file path
      // This assumes the file path starts with the user's UID
      allow write: if request.auth != null && request.resource.name.startsWith(request.auth.uid + '/');
    }
  }
}